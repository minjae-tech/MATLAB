clear;
clc;

x = input('두 수를 입력하시오 (ex=[a b]): ');
a = x(1);
b = x(2);

cmd = input('연산 입력 (add, sub, mul, div): ', 's');

switch cmd
    case 'add'
        result = a + b;
        disp(result)

    case 'sub'
        result = a - b;
        disp(result)

    case 'mul'
        result = a * b;
        disp(result)

    case 'div'
        if b == 0
            disp('division by zero')
        else
            result = a / b;
            disp(result)
        end

    otherwise
        disp('invalid command')
end

