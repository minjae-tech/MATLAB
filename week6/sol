%P9

clear
clc

% 연결 형태 입력
type = input('연결 형태 입력 (series / parallel): ', 's');

% 저항 개수 입력
n = input('저항 개수 n 입력: ');

% 저항 값 입력
R = input('저항 값 입력 (예: [R1 R2 ...]): ');

Req = 0;

switch type
    case 'series'   % 직렬
        for i = 1:n
            Req = Req + R(i);
        end

    case 'parallel' % 병렬
        for i = 1:n
            Req = Req + 1/R(i);
        end
        Req = 1 / Req;

    otherwise
        disp('invalid connection type')
        return
end

% 결과 출력
fprintf('등가 저항 = %.4f\n', Req);













